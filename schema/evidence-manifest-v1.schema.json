{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/WoolData/visual-evidence/schema/evidence-manifest-v1.schema.json",
  "title": "Visual Evidence Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "snapshot", "revision", "environment", "captures"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "snapshot": { "enum": ["before", "after"] },
    "revision": { "type": "string", "pattern": "^(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})$" },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os",
        "architecture",
        "runnerImage",
        "captureAdapter",
        "adapterVersion",
        "renderer",
        "renderScale",
        "fontSetHash",
        "compatibilityKey"
      ],
      "properties": {
        "os": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "runnerImage": { "type": "string", "minLength": 1 },
        "captureAdapter": { "type": "string", "minLength": 1 },
        "adapterVersion": { "type": "string", "minLength": 1 },
        "renderer": { "type": "string", "minLength": 1 },
        "renderScale": { "type": "number", "exclusiveMinimum": 0 },
        "fontSetHash": { "type": "string", "minLength": 1 },
        "compatibilityKey": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "captures": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "label", "path", "width", "height", "sha256"],
        "properties": {
          "key": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]{0,159}$" },
          "label": { "type": "string", "minLength": 1, "maxLength": 200 },
          "path": { "type": "string", "pattern": "^[^/\\\\].*\\.[Pp][Nn][Gg]$" },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    }
  }
}
